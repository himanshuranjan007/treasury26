# Multi-stage Dockerfile for NEAR Treasury Sandbox Test Environment
# Builds and runs:
# - NEAR Sandbox (via near-sandbox binary)
# - Bulk Payment Contract
# - Treasury Backend (nt-be)
# - Sputnik DAO Indexer (proposal caching)

# ============================================================================
# Stage 1: Build the Bulk Payment Contract
# ============================================================================
# cargo-near 0.17.0 requires Rust 1.89+, but the contract needs Rust 1.86
FROM rust:1.90 AS contract-builder

WORKDIR /build

# Install cargo-near via pre-built binary (much faster than cargo install)
RUN curl --proto '=https' --tlsv1.2 -LsSf https://github.com/near/cargo-near/releases/download/cargo-near-v0.17.0/cargo-near-installer.sh | sh

# Install Rust 1.86 toolchain for building the contract
RUN rustup install 1.86.0 && rustup target add wasm32-unknown-unknown --toolchain 1.86.0

COPY contracts/bulk-payment/Cargo.toml contracts/bulk-payment/Cargo.lock* ./
COPY contracts/bulk-payment/src ./src

# Create rust-toolchain.toml to use Rust 1.86 for this crate
RUN echo '[toolchain]\nchannel = "1.86.0"' > rust-toolchain.toml

RUN cargo near build non-reproducible-wasm

# ============================================================================
# Stage 2: Build the Sandbox Initializer
# ============================================================================
FROM rust:1.90 AS sandbox-builder

WORKDIR /build

RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

COPY sandbox/sandbox-init/Cargo.toml sandbox-init/
COPY sandbox/sandbox-init/src sandbox-init/src
COPY sandbox/contracts/ contracts/

RUN cd sandbox-init && cargo build --release

# ============================================================================
# Stage 3: Build the Treasury Backend (nt-be)
# ============================================================================
FROM rust:1.90 AS api-builder

WORKDIR /build

RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Mirror the repo layout: `shared/` is a sibling of the `nt-be` crate root so the
# `include_str!("../../../../shared/...")` path in templates.rs resolves at build time.
COPY nt-be/Cargo.toml nt-be/Cargo.lock nt-be/
COPY nt-be/src nt-be/src
COPY nt-be/migrations nt-be/migrations
COPY nt-be/.sqlx nt-be/.sqlx
COPY nt-be/data nt-be/data
COPY shared/ shared/

ENV SQLX_OFFLINE=true
RUN cd nt-be && cargo build --release

# ============================================================================
# Stage 4: Build the Sputnik Indexer
# ============================================================================
FROM rust:1.90 AS indexer-builder

WORKDIR /app

RUN git clone --depth 1 https://github.com/near-daos/sputnik-dao-caching-api-server.git .
RUN cargo build --release --bin sputnik-indexer

# ============================================================================
# Stage 5: Runtime environment
# ============================================================================
FROM debian:trixie-slim AS runtime

RUN apt-get update && apt-get install -y \
    curl \
    supervisor \
    ca-certificates \
    socat \
    postgresql \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy built binaries
COPY --from=sandbox-builder /build/sandbox-init/target/release/sandbox-init /usr/local/bin/
COPY --from=api-builder /build/nt-be/target/release/nt-be /usr/local/bin/
COPY --from=indexer-builder /app/target/release/sputnik-indexer /usr/local/bin/

# Copy contract WASM
COPY --from=contract-builder /build/target/near/bulk_payment_contract.wasm /app/contracts/bulk_payment.wasm

# Copy configuration files
COPY sandbox/supervisord.conf /etc/supervisor/conf.d/
COPY sandbox/start-sandbox.sh /usr/local/bin/
COPY sandbox/start-postgres.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/start-sandbox.sh /usr/local/bin/start-postgres.sh

# Copy additional contracts (DAO factory, wrap.near, etc.)
COPY sandbox/contracts/ /app/contracts/


# Create directories
RUN mkdir -p /data /var/log

# Expose ports
# 3030 - NEAR RPC
# 8080 - Treasury API
# 5001 - Sputnik Indexer
# 5432 - PostgreSQL
EXPOSE 3030 4000 8080 5001 5432

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8080/api/health || exit 1

CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/supervisord.conf"]
